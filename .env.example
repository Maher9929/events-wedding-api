# ============================================================
# Doha Events - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Configuration
JWT_SECRET=generate-a-random-64-char-hex-string

# Server port
PORT=3000

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL (used in email templates)
APP_BASE_URL=https://yourdomain.com

# SendGrid Configuration (optional — emails disabled without it)
SENDGRID_API_KEY=SG.your-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Doha Events

# Redis (optional — falls back to in-memory cache)
# REDIS_URL=redis://localhost:6379

# AI Chatbot (Gemini / OpenAI / any OpenAI-compatible API)
CHATBOT_API_KEY=your-api-key
# CHATBOT_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# CHATBOT_MODEL=gemini-2.0-flash
