# Compose images
COMPOSE_PROJECT_NAME=doha-events-prod
APP_ENV_FILE=.env.production.example
BACKEND_IMAGE=ghcr.io/your-org/doha-events-backend
FRONTEND_IMAGE=ghcr.io/your-org/doha-events-frontend
IMAGE_TAG=latest

# Public domains handled by Caddy
FRONTEND_DOMAIN=events.example.com
API_DOMAIN=api.events.example.com
ACME_EMAIL=ops@example.com

# Server
PORT=3000
NODE_ENV=production

# Security
JWT_SECRET=change_me_with_at_least_32_characters
ALLOWED_ORIGINS=https://events.example.com
APP_BASE_URL=https://events.example.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PUBLISHABLE_KEY=pk_live_your_key

# Redis
REDIS_PASSWORD=change_me_with_a_long_random_password

# Email, optional
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Doha Events

# Monitoring, optional
SENTRY_DSN=
